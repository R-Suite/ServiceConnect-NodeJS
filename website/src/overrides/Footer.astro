---
import Default from '@astrojs/starlight/components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Default><slot /></Default>

<footer class="sc-footer" role="contentinfo">
  <div class="sc-footer__inner">
    <p class="sc-footer__left">
      &copy; {new Date().getFullYear()} ServiceConnect contributors. Licensed under
      <a href="https://opensource.org/licenses/MIT" rel="noreferrer">MIT</a>.
    </p>
    <nav class="sc-footer__right" aria-label="Footer">
      <a href="https://github.com/R-Suite/ServiceConnect-NodeJS" rel="noreferrer">GitHub &#x2197;</a>
      <a href="https://www.npmjs.com/package/@serviceconnect/core" rel="noreferrer">npm &#x2197;</a>
      <a href={`${base}/releases/`}>Releases</a>
    </nav>
  </div>
</footer>

<style>
  .sc-footer {
    border-top: 1px solid var(--sl-color-hairline);
    padding: 1.25rem 1rem;
    margin-top: 3rem;
    font-size: 0.875rem;
    color: var(--sl-color-text-muted);
  }

  .sc-footer__inner {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    justify-content: space-between;
    align-items: center;
  }

  .sc-footer__right {
    display: flex;
    gap: 1.25rem;
  }

  .sc-footer a {
    color: inherit;
    text-decoration: none;
  }

  .sc-footer a:hover,
  .sc-footer a:focus-visible {
    color: var(--sl-color-accent);
    text-decoration: underline;
  }
</style>
