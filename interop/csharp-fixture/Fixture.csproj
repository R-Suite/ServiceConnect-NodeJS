<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Minimal C# `master` ServiceConnect fixture used to prove cross-runtime interop with the Node.js
    bus (see interop/run.sh and packages/rabbitmq/test/e2e/interop-master.test.ts). References the
    PUBLISHED master packages (the deployed wire format). Targets net10.0 because that is the runtime
    available here; the ServiceConnect net6.0 libraries are forward-compatible with it.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>Interop.Fixture</AssemblyName>
    <RootNamespace>Interop.Fixture</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ServiceConnect" Version="5.0.8" />
  </ItemGroup>

</Project>
